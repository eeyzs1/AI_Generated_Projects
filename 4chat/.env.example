# 4Chat 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 密钥（必填，生产环境请替换为随机字符串）──────────────────
SECRET_KEY=your-secret-key-change-in-production
ACCESS_SECRET_KEY=your-secret-key-change-in-production

# ── MySQL ────────────────────────────────────────────────────
# 本地 Docker：mysql+pymysql://root:root123@mysql:3306/<db>
# 云服务示例：mysql+pymysql://user:password@your-rds-host:3306/<db>
MYSQL_USER_URL=mysql+pymysql://root:root123@mysql:3306/im_user
MYSQL_GROUP_URL=mysql+pymysql://root:root123@mysql:3306/im_group
MYSQL_STORAGE_URL=mysql+pymysql://root:root123@mysql:3306/im_storage

# ── Redis（三选一）──────────────────────────────────────────
# 普通模式
REDIS_URL=redis://redis:6379/0

# 哨兵模式（注释掉 REDIS_URL，取消注释以下两行）
# REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_MASTER=mymaster

# 集群模式（注释掉 REDIS_URL，取消注释以下一行）
# REDIS_CLUSTER_HOSTS=redis-cluster-0:6379,redis-cluster-1:6379,redis-cluster-2:6379

# ── Celery（Redis db1=db2 隔离）─────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── ScyllaDB ─────────────────────────────────────────────────
SCYLLA_HOSTS=scylladb
SCYLLA_PORT=9042

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ── Nacos ────────────────────────────────────────────────────
NACOS_HOST=nacos
NACOS_PORT=8848

# ── SMTP 邮件 ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── CDN ──────────────────────────────────────────────────────
# 留空则不使用 CDN，文件通过 storage-service 直接提供
CDN_BASE_URL=
# 生产环境示例：https://cdn.4chat.example.com

# ── 前端 ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
